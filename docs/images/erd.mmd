erDiagram
    users {
        bigint uuid PK
        varchar username UK
        varchar email UK
        varchar nickname
    }

    budgets {
        bigint uuid PK
        bigint uuid_user FK
        char year_month
        decimal amount
    }

    categories {
        bigint uuid PK
        varchar code
        varchar name
        tinyint type "0=지출, 1=수입"
    }

    recurring_items {
        bigint uuid PK
        bigint uuid_user FK
        bigint uuid_category FK
        tinyint type "0=지출, 1=수입"
        varchar name
        decimal amount
        tinyint billing_day
        tinyint is_active
    }

    transactions {
        bigint uuid PK
        bigint uuid_user FK
        bigint uuid_category FK
        bigint uuid_recurring_item FK
        tinyint type "0=지출, 1=수입"
        decimal amount
        varchar memo
        date transaction_date
    }

    users ||--o{ budgets : "uuid_user"
    users ||--o{ recurring_items : "uuid_user"
    users ||--o{ transactions : "uuid_user"
    categories ||--o{ recurring_items : "uuid_category"
    categories ||--o{ transactions : "uuid_category"
    recurring_items |o--o{ transactions : "uuid_recurring_item"
